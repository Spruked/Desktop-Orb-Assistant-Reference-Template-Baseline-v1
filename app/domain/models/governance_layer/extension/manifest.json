{
  "manifest_version": 3,
  "name": "LLM Governance Layer",
  "version": "1.0.0",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://chat.openai.com/*", "https://claude.ai/*"],
  "content_scripts": [
    {
      "matches": ["https://chat.openai.com/*", "https://claude.ai/*"],
      "js": ["content.js"],
      "css": ["governance.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
